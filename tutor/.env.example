# Manim 渲染服务配置示例
# 复制此文件为 .env 并填入实际值

# 远程服务地址
MANIM_SERVICE_URL=http://YOUR_SERVER_IP:8000

# 服务器 IP（可选，与 SERVICE_URL 一致）
MANIM_SERVER_IP=YOUR_SERVER_IP

# SSH 登录用户（可选）
MANIM_SERVER_USER=ubuntu

# SSH 密码（可选，建议使用 SSH 密钥）
# MANIM_SERVER_PASSWORD=your-password

# 服务器项目目录（可选）
MANIM_SERVER_BASE_DIR=/home/ubuntu/math/projects
